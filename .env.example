# Скопируйте в .env и при необходимости отредактируйте.

# Async URL для FastAPI (драйвер asyncpg). Sync-URL для воркера выводится автоматически.
DATABASE_URL=postgresql+asyncpg://mltrading:mltrading@localhost:5432/mltrading

# Корень с артефактами (parquets/, runs/, models/ ...). По умолчанию — корень репозитория.
# Чтобы переиспользовать данные ноутбучного проекта, укажите его путь:
# PROJECT_ROOT=/home/Artem/ml-trading

# CORS для будущего фронтенда
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Параметры MOEX по умолчанию
MOEX_BOARD=TQBR
MOEX_INTERVAL=1
MOEX_CONCURRENCY=5

# Интерпретатор для воркера обучения (subprocess). По умолчанию — текущий sys.executable.
# TRAINING_PYTHON=/home/Artem/ml-runner-backend/.venv/bin/python
